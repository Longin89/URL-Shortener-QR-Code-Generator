# Environment Configuration Example
# Скопируйте этот файл в .env и настройте под свои нужды

# Database Configuration
DB_HOST=mysql
DB_NAME=yii
DB_USER=root
DB_PASSWORD=yii

# Application
APP_DEBUG=true
APP_ENV=dev

# Docker Ports
NGINX_PORT=80
PHPMYADMIN_PORT=8080

# MySQL
MYSQL_ROOT_PASSWORD=yii
MYSQL_DATABASE=yii
MYSQL_USER=yii
MYSQL_PASSWORD=yii
