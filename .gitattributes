# Auto detect text files and perform LF normalization
* text=auto

# Shell scripts
*.sh text eol=lf

# PHP files
*.php text eol=lf diff=php

# JavaScript
*.js text eol=lf

# CSS
*.css text eol=lf

# SQL
*.sql text eol=lf

# Configuration files
*.ini text eol=lf
*.conf text eol=lf
*.cnf text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.json text eol=lf

# Docker files
Dockerfile text eol=lf
docker-compose.yml text eol=lf
compose.yaml text eol=lf

# Documentation
*.md text eol=lf
*.txt text eol=lf

# Images
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg text

# Archives
*.zip binary
*.tar binary
*.gz binary
*.phar binary
